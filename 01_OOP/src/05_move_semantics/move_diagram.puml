@startuml move_diagram

skinparam backgroundColor #FAFAFA
skinparam class {
    BackgroundColor #FFF3E0
    BorderColor #E65100
}

title Move Semantics – klasa Buffer

class Buffer {
    + name_ : string
    + size_ : size_t
    + data_ : int*  <<ptr>>
    --
    + Buffer(name, size) <<ctor>>
    + Buffer(other: Buffer&) <<copy ctor>>
    + Buffer(other: Buffer&&) <<move ctor>>
    + operator=(other: Buffer&) : Buffer& <<copy assign>>
    + operator=(other: Buffer&&) : Buffer& <<move assign>>
    + ~Buffer()
    --
    + print() : void
    + valid() : bool
}

rectangle "Heap A\n[0,1,2,3,4]" as heapA #FFCCBC
rectangle "Heap B (kopia)\n[0,1,2,3,4]" as heapB #FFF9C4
rectangle "Heap A (przejęty)" as heapMove #C8E6C9

note top of Buffer
  KOPIA: data_ → nowy blok
  ──────────────────────────
  b1.data_ ──► Heap A
  b2.data_ ──► Heap B (kopia)
  Koszt: alokacja + memcpy

  MOVE: data_ przejęty
  ──────────────────────────
  b1.data_ → nullptr (invalidated)
  b3.data_ ──► Heap A (ten sam!)
  Koszt: brak alokacji – tylko pointer swap
end note

note right of Buffer
  noexcept na move ctor/op=
  jest WYMAGANE by std::vector
  mógł używać move zamiast copy
  przy realokacji!
end note

@enduml
